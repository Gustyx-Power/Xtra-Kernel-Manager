<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
    </style>

    <!-- Tema kustom untuk aktivitas SysDestroyedEasterEgg -->
    <style name="Theme.SysDestroyed" parent="Theme.AppCompat.NoActionBar">
        <!-- Tema ini bisa diubah sesuai kebutuhan -->
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">@drawable/system_destroyed</item>  <!-- Gambar background -->
    </style>

    <style name="SpinnerItemStyle">
        <item name="android:textColor">@color/white</item>
        <item name="android:fontFamily">@font/bold_ptsans</item>
    </style>

</resources>