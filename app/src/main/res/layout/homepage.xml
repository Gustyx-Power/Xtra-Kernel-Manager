<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/greenlight" >




    <ImageView
        android:id="@+id/xkmheader"
        android:layout_width="467dp"
        android:layout_height="85dp"
        android:src="@drawable/header_xkm"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.019"
        tools:ignore="ContentDescription,MissingConstraints,VisualLintBounds" />

    <ImageView
        android:id="@+id/shapecpu"
        android:layout_width="402dp"
        android:layout_height="206dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/cpus_shape"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.666"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/xkmheader"
        app:layout_constraintVertical_bias="0.0"
        tools:ignore="ContentDescription,HardcodedText" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.54" />

    <TextView
        android:id="@+id/cpuCore0"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="84dp"
        android:layout_marginTop="35dp"
        android:fontFamily="@font/inter"
        android:text="N/A"
        android:textColor="@color/white"
        android:textSize="18sp"
        app:layout_constraintStart_toStartOf="@+id/shapecpu"
        app:layout_constraintTop_toTopOf="@+id/shapecpu"
        tools:ignore="HardcodedText,MissingConstraints" />

    <TextView
        android:id="@+id/cpuCore1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="84dp"
        android:layout_marginTop="4dp"
        android:fontFamily="@font/inter"
        android:text="N/A"
        android:textColor="@color/white"
        android:textSize="18sp"
        app:layout_constraintStart_toStartOf="@+id/shapecpu"
        app:layout_constraintTop_toBottomOf="@+id/cpuCore0"
        tools:ignore="HardcodedText,MissingConstraints" />

    <TextView
        android:id="@+id/cpuCore2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="84dp"
        android:layout_marginTop="4dp"
        android:fontFamily="@font/inter"
        android:text="N/A"
        android:textColor="@color/white"
        android:textSize="18sp"
        app:layout_constraintStart_toStartOf="@+id/shapecpu"
        app:layout_constraintTop_toBottomOf="@+id/cpuCore1"
        tools:ignore="HardcodedText,MissingConstraints" />

    <TextView
        android:id="@+id/cpuCore3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:fontFamily="@font/inter"
        android:text="N/A"
        android:textColor="@color/white"
        android:textSize="18sp"
        app:layout_constraintStart_toStartOf="@+id/cpuCore2"
        app:layout_constraintTop_toBottomOf="@+id/cpuCore2"
        tools:ignore="HardcodedText,MissingConstraints" />

    <TextView
        android:id="@+id/cpuCore4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="35dp"
        android:fontFamily="@font/inter"
        android:text="N/A"
        android:textColor="@color/white"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="@+id/shapecpu"
        app:layout_constraintHorizontal_bias="0.61"
        app:layout_constraintStart_toEndOf="@+id/cpuCore0"
        app:layout_constraintTop_toTopOf="@+id/shapecpu"
        tools:ignore="HardcodedText,MissingConstraints" />

    <TextView
        android:id="@+id/cpuCore5"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:fontFamily="@font/inter"
        android:text="N/A"
        android:textColor="@color/white"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="@+id/shapecpu"
        app:layout_constraintHorizontal_bias="0.61"
        app:layout_constraintStart_toEndOf="@+id/cpuCore1"
        app:layout_constraintTop_toBottomOf="@id/cpuCore4"
        tools:ignore="HardcodedText" />

    <TextView
        android:id="@+id/cpuCore6"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:fontFamily="@font/inter"
        android:text="N/A"
        android:textColor="@color/white"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="@+id/shapecpu"
        app:layout_constraintHorizontal_bias="0.61"
        app:layout_constraintStart_toEndOf="@+id/cpuCore2"
        app:layout_constraintTop_toBottomOf="@id/cpuCore5"
        tools:ignore="HardcodedText" />

    <TextView
        android:id="@+id/cpuCore7"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:fontFamily="@font/inter"
        android:text="N/A"
        android:textColor="@color/white"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="@+id/shapecpu"
        app:layout_constraintHorizontal_bias="0.61"
        app:layout_constraintStart_toEndOf="@+id/cpuCore3"
        app:layout_constraintTop_toBottomOf="@id/cpuCore6"
        tools:ignore="HardcodedText" />

    <TextView
        android:id="@+id/cpuGov"
        android:layout_width="143dp"
        android:layout_height="34dp"
        android:layout_marginStart="12dp"
        android:fontFamily="@font/inter"
        android:text="CPU Governor : N/A"
        android:textColor="@color/white"
        app:layout_constraintBottom_toBottomOf="@+id/shapecpu"
        app:layout_constraintStart_toStartOf="@+id/shapecpu"
        app:layout_constraintTop_toBottomOf="@+id/cpuCore3"
        app:layout_constraintVertical_bias="1.0"
        tools:ignore="HardcodedText,MissingConstraints,TextSizeCheck" />

    <TextView
        android:id="@+id/cpuMax"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="176dp"
        android:fontFamily="@font/inter"
        android:text="CPU Max: N/A"
        android:textColor="@color/white"
        app:layout_constraintBottom_toBottomOf="@+id/shapecpu"
        app:layout_constraintEnd_toEndOf="@+id/shapecpu"
        app:layout_constraintHorizontal_bias="0.816"
        app:layout_constraintStart_toEndOf="@+id/cpuGov"
        app:layout_constraintTop_toBottomOf="@+id/xkmheader"
        app:layout_constraintVertical_bias="0.071"
        tools:ignore="HardcodedText" />

    <TextView
        android:id="@+id/kernelName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/inter"
        android:text="Kernel Name: N/A"
        android:textColor="@color/white"
        android:textSize="18sp"
        tools:ignore="HardcodedText,MissingConstraints,TextContrastCheck"
        tools:layout_editor_absoluteX="25dp"
        tools:layout_editor_absoluteY="484dp" />

    <TextView
        android:id="@+id/rootStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginTop="156dp"
        android:fontFamily="@font/inter"
        android:text="Root Access : N/A"
        android:textColor="@color/white"
        android:textSize="18sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/kernelName"
        tools:ignore="HardcodedText,TextContrastCheck" />

    <TextView
        android:id="@+id/rootProvider"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginTop="140dp"
        android:fontFamily="@font/inter"
        android:text="RootManager : N/A"
        android:textColor="@color/white"
        android:textSize="18sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/rootStatus"
        tools:ignore="HardcodedText,TextContrastCheck,VisualLintBounds" />

    <Button
        android:id="@+id/btnOpenSettings"
        android:layout_width="150dp"
        android:layout_height="45dp"
        android:text="CPU / GPU"
        android:textSize="18sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/rootProvider"
        app:layout_constraintVertical_bias="0.95"
        tools:ignore="HardcodedText,TouchTargetSizeCheck,VisualLintBounds" />

    <ImageView
        android:id="@+id/shapetemp"
        android:layout_width="402dp"
        android:layout_height="36dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/shape_cputemp_gpu"
        app:layout_constraintEnd_toEndOf="@+id/shapecpu"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="@+id/shapecpu"
        app:layout_constraintTop_toBottomOf="@+id/shapecpu"
        tools:ignore="ContentDescription,MissingConstraints" />

    <TextView
        android:id="@+id/cpuTemperature"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="12dp"
        android:fontFamily="@font/inter"
        android:text="Temp CPU: N/A"
        android:textColor="@color/white"
        android:textSize="10sp"
        app:layout_constraintStart_toStartOf="@+id/shapetemp"
        app:layout_constraintTop_toTopOf="@+id/shapetemp"
        tools:ignore="HardcodedText,SmallSp" />

    <TextView
        android:id="@+id/socTemperature"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:fontFamily="@font/inter"
        android:text="Temp SOC: N/A"
        android:textColor="@color/white"
        android:textSize="10sp"
        app:layout_constraintEnd_toEndOf="@+id/shapetemp"
        app:layout_constraintHorizontal_bias="0.96"
        app:layout_constraintStart_toStartOf="@+id/shapetemp"
        app:layout_constraintTop_toTopOf="@+id/shapetemp"
        tools:ignore="HardcodedText,SmallSp" />


    <ImageView
        android:id="@+id/shapegputemp"
        android:layout_width="402dp"
        android:layout_height="36dp"
        android:layout_marginTop="48dp"
        android:background="@drawable/shape_cputemp_gpu"
        app:layout_constraintEnd_toEndOf="@+id/shapecpu"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@+id/shapecpu"
        app:layout_constraintTop_toBottomOf="@+id/shapecpu"
        tools:ignore="ContentDescription,MissingConstraints" />

    <TextView
        android:id="@+id/gpuFrequency"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="12dp"
        android:fontFamily="@font/inter"
        android:text="GPU Freq: N/A"
        android:textColor="@color/white"
        android:textSize="10sp"
        app:layout_constraintStart_toStartOf="@+id/shapegputemp"
        app:layout_constraintTop_toTopOf="@+id/shapegputemp"
        tools:ignore="HardcodedText,SmallSp" />

    <TextView
        android:id="@+id/gpuMaxFrequency"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:fontFamily="@font/inter"
        android:text="GPU Max Freq: N/A"
        android:textColor="@color/white"
        android:textSize="10sp"
        app:layout_constraintEnd_toEndOf="@+id/shapegputemp"
        app:layout_constraintHorizontal_bias="0.958"
        app:layout_constraintStart_toStartOf="@+id/shapegputemp"
        app:layout_constraintTop_toTopOf="@+id/shapegputemp"
        tools:ignore="HardcodedText,SmallSp" />


    <ImageView
        android:id="@+id/rootshape"
        android:layout_width="407dp"
        android:layout_height="125dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/shape_root"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/shapegputemp"
        tools:ignore="ContentDescription" />

    <TextView
        android:id="@+id/rootStatus"
        android:layout_width="231dp"
        android:layout_height="46dp"
        android:layout_marginTop="44dp"
        android:layout_marginEnd="16dp"
        android:fontFamily="@font/inter"
        android:text="Root Access: N/A"
        android:textColor="@color/white"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/shapegputemp"
        tools:ignore="HardcodedText,MissingConstraints,TextContrastCheck" />

    <TextView
        android:id="@+id/rootProvider"
        android:layout_width="210dp"
        android:layout_height="58dp"
        android:layout_marginTop="72dp"
        android:layout_marginEnd="108dp"
        android:fontFamily="@font/inter"
        android:text="RootManager : N/A"
        android:textColor="@color/white"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="@+id/rootshape"
        app:layout_constraintHorizontal_bias="0.024"
        app:layout_constraintStart_toStartOf="@+id/rootStatus"
        app:layout_constraintTop_toTopOf="@+id/rootshape"
        tools:ignore="HardcodedText,TextContrastCheck,VisualLintBounds" />

    <ImageView
        android:id="@+id/rootProviderLogo"
        android:layout_width="84dp"
        android:layout_height="90dp"
        android:layout_marginTop="8dp"
        android:contentDescription="Root Provider Logo"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.14"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/rootshape"
        tools:ignore="HardcodedText" />


</androidx.constraintlayout.widget.ConstraintLayout>
